# Copy to .env for local development.
# In Vercel: Project → Settings → Environment Variables (add all for Production, Preview, Development).

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Settings → API → anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Optional — used by some tooling; not required by the app runtime
VITE_SUPABASE_PROJECT_ID=your-project-ref
